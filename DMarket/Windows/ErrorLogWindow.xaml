<Window x:Class="DMarket.Windows.ErrorLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エラー確認"
        Width="900"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FB">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="デバッグログ"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#102A43"/>
            <TextBlock Text="デバッグモードがONの間だけ、アプリ起動中のエラーを最大200件保持します。"
                       Margin="0,6,0,0"
                       Foreground="#52606D"/>
        </StackPanel>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Background="White"
                 Foreground="#1F2937"
                 BorderBrush="#CBD2D9"
                 BorderThickness="1"
                 Padding="12"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="更新"
                    Width="96"
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Click="Refresh_Click"/>
            <Button Content="コピー"
                    Width="96"
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Click="Copy_Click"/>
            <Button Content="クリア"
                    Width="96"
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Click="Clear_Click"/>
            <Button Content="閉じる"
                    Width="96"
                    Padding="16,8"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
